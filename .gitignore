# Python caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Virtual environments and local env files
.env
.env.*
.venv/
venv/
env/

# Experiment outputs and generated reports
outputs/
runs/
logs/
checkpoints/
wandb/
tensorboard/
README.pdf

# Model checkpoints and training artifacts
*.pt
*.pth
*.ckpt
*.onnx

# Dataset files and generated fixtures
data/
datasets/
cifar-10/
*.npz
*.npy
*.pkl
*.pickle
tests/_smoke_outputs/
tests/tiny_dataset.npz

# Generated figures/tables outside the standard output dirs
*.png
*.jpg
*.jpeg
*.csv

# Keep source and configuration files visible even if patterns above expand later.
!README.md
!configs/
!configs/*.yaml
!jscc_lab/
!jscc_lab/*.py
!scripts/
!scripts/*.py
!tests/
!tests/*.py
